# ----------------------------------------------------------------- DATA project
# The app's OWN Supabase project (owns the `panel` schema). UNCHANGED by the
# Sunday Account host login. Anonymous join/play/board all run off this.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_BASE_URL=https://panel.sundaysuite.app

# ------------------------------------------------ Sunday Account (ISSUER) project
# Host/arrangør login ONLY (magic link + Google). This is a SEPARATE Supabase
# project — the shared identity issuer that owns the `sb-*` session cookie on
# `.sundaysuite.app`. Use SundayInfo's NEXT_PUBLIC_SUPABASE_URL / ANON_KEY
# values here (the SundayPlans / identity project). The DATA project above stays
# untouched and SESSION-LESS so the two clients never fight over cookies.
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-ISSUER-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=issuer-anon-key

# Comma/space-separated allow-list of arrangør emails. ONLY these Sunday
# accounts get host access (the "Mine paneler" dashboard + owner stamp). Empty
# = no one is a host (fails closed). Never affects anonymous code-based play.
PANEL_ADMIN_EMAILS=arrangor@menigheten.no

# PRODUCTION ONLY: scope the Sunday Account session cookie to the parent domain
# so one login spans every *.sundaysuite.app app. Leave UNSET in local dev
# (cookies must stay on localhost).
# NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app

# Optional: enables the moderator 'Rydd opp' AI pass (clustering + soft flags +
# rephrase suggestions). SERVER-ONLY — never exposed to the client bundle. With
# no key set, 'Rydd opp' reports "AI ikke konfigurert" and manual moderation is
# unaffected. Set as a Cloudflare Worker secret in production
# (`wrangler secret put ANTHROPIC_API_KEY`).
# ANTHROPIC_API_KEY=sk-ant-...
